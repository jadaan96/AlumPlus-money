{
  "name": "workshop-accounts",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w workshop-backend\" \"npm run dev -w @workshop/web\"",
    "build": "npm run build -w @workshop/shared && npm run build -w workshop-backend && npm run build -w @workshop/web",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:start": "powershell -ExecutionPolicy Bypass -File scripts/start-postgres.ps1",
    "db:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-db.ps1",
    "db:migrate": "npm run db:migrate -w workshop-backend",
    "db:deploy": "npm run db:deploy -w workshop-backend",
    "db:seed": "npm run db:seed -w workshop-backend",
    "db:backup": "powershell -ExecutionPolicy Bypass -File scripts/backup-db.ps1",
    "db:backup:schedule": "powershell -ExecutionPolicy Bypass -File scripts/register-backup-schedule.ps1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
