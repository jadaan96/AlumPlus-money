# اتصال PostgreSQL (استضافة أو Docker أو محلي)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

PORT=4000
# دومين الواجهة؛ عدة قيم مفصولة بفاصلة: https://app.example.com,https://www.example.com
CORS_ORIGIN="http://localhost:5173"

# خلف reverse proxy (Railway, Render, nginx)
# TRUST_PROXY=1

ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"
